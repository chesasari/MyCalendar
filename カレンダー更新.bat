@echo off
chcp 65001 > nul
echo ========================================================
echo 出社場所カレンダー データ抽出ツール
echo ========================================================
echo.
echo ダウンロードフォルダにある「出社ローテ.xlsx」を読み込みます...
python extract_data.py
if %errorlevel% neq 0 (
    echo.
    echo [エラー] データの抽出に失敗しました。
    echo Pythonがインストールされているか、または「出社ローテ.xlsx」がダウンロードフォルダにあるか確認してください。
    echo エンターを押して終了してください。
    pause > nul
    exit /b
)
echo.
echo ========================================================
echo ［完了］ データの抽出が成功しました！
echo ローカル画面に反映されます。
echo ※GitHubPagesへのアップロードは、VSCodeなどから手動で行ってください。
echo エンターを押して画面を閉じます。
echo ========================================================
pause > nul
